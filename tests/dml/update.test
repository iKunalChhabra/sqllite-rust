# UPDATE error tests ported from SQLite test/update.test
# (UPDATE execution not yet implemented; error-path tests only)

do_test update-1.1 {
  set v [catch {execsql {UPDATE test1 SET f2=5 WHERE f1<1}} msg]
  lappend v $msg
} {1 {no such table: test1}}

do_test update-3.1 {
  execsql {CREATE TABLE test1(f1 int,f2 int)}
  execsql {INSERT INTO test1 VALUES(1,2)}
  execsql {INSERT INTO test1 VALUES(3,4)}
  execsql {SELECT * FROM test1}
} {1 2 3 4}
