# DDL tests ported from SQLite test/insert.test, test/select1.test (create portions)

do_execsql_test create-1.1 {
  CREATE TABLE t1(x int);
  INSERT INTO t1 VALUES(42);
  SELECT x FROM t1;
} {42}

do_execsql_test create-1.2 {
  CREATE TABLE t2(a int, b int, c int);
  INSERT INTO t2 VALUES(1, 2, 3);
  SELECT a, b, c FROM t2;
} {1 2 3}

do_execsql_test create-1.3 {
  CREATE TABLE "quoted name"(v int);
  INSERT INTO "quoted name" VALUES(7);
  SELECT v FROM "quoted name";
} {7}

do_test create-err-2 {
  execsql {CREATE TABLE dup_t(x int)}
  set v [catch {execsql {CREATE TABLE dup_t(y int)}} msg]
  lappend v $msg
} {1 {table dup_t already exists}}
