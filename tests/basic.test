# Basic INSERT tests ported from SQLite test/insert.test

do_test insert-1.1 {
  set v [catch {execsql {INSERT INTO test1 VALUES(1,2,3)}} msg]
  lappend v $msg
} {1 {no such table: test1}}

do_test insert-1.3 {
  execsql {CREATE TABLE test1(one int, two int, three int)}
  set v [catch {execsql {INSERT INTO test1 VALUES(1,2)}} msg]
  lappend v $msg
} {1 {table test1 has 3 columns but 2 values were supplied}}

do_test insert-1.5 {
  execsql {INSERT INTO test1 VALUES(1,2,3)}
  execsql {SELECT * FROM test1}
} {1 2 3}

do_test insert-1.5b {
  execsql {INSERT INTO test1 VALUES(4,5,6)}
  execsql {SELECT * FROM test1 ORDER BY one}
} {1 2 3 4 5 6}

do_test insert-1.4 {
  execsql {CREATE TABLE test2(a int, b int, c int)}
  set v [catch {execsql {INSERT INTO test2(a,d) VALUES(1,2)}} msg]
  lappend v $msg
} {1 {table test2 has no column named d}}

do_test create-1.1 {
  execsql {CREATE TABLE t1(x int)}
  execsql {INSERT INTO t1 VALUES(42)}
  execsql {SELECT x FROM t1}
} {42}

do_test select-1.1 {
  execsql {CREATE TABLE t2(a int, b int)}
  execsql {INSERT INTO t2 VALUES(10,20)}
  execsql {SELECT a, b FROM t2}
} {10 20}

do_test delete-1.1 {
  execsql {CREATE TABLE t3(v int)}
  execsql {INSERT INTO t3 VALUES(1)}
  execsql {INSERT INTO t3 VALUES(2)}
  execsql {DELETE FROM t3 WHERE v=1}
  execsql {SELECT v FROM t3}
} {2}
