# Expression tests (simplified from SQLite test/expr.test — table-scoped literals)

reset_db

do_execsql_test expr-from-table-1 {
  CREATE TABLE t(x int);
  INSERT INTO t VALUES(1);
  SELECT 10+20 FROM t;
} {30}

do_execsql_test expr-from-table-2 {
  CREATE TABLE t2(x int);
  INSERT INTO t2 VALUES(1);
  SELECT 2*3+4 FROM t2;
} {10}

do_execsql_test expr-from-table-3 {
  CREATE TABLE t3(x int);
  INSERT INTO t3 VALUES(1);
  SELECT 6*7 FROM t3;
} {42}

do_execsql_test expr-from-table-4 {
  CREATE TABLE t4(x int);
  INSERT INTO t4 VALUES(1);
  SELECT 20/4 FROM t4;
} {5}

do_execsql_test expr-from-table-5 {
  CREATE TABLE t5(x int);
  INSERT INTO t5 VALUES(1);
  SELECT 2+3*4 FROM t5;
} {14}
